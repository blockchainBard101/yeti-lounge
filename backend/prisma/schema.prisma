datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  suiAddress   String    @id
  suinsHandle  String?
  avatarBlobId String?
  bio          String?
  createdAt    DateTime  @default(now())

  posts        Post[]
  comments     Comment[]
  rsvps        Rsvp[]
  questCompletions QuestCompletion[]
}

model Post {
  objectId      String    @id // Sui object ID of the post
  authorAddress String
  textContent   String
  mediaBlobId   String?
  yerrsCount    Int       @default(0)
  upvotes       Int       @default(0)
  downvotes     Int       @default(0)
  likes         Int       @default(0)
  createdAt     DateTime  @default(now())

  author        User      @relation(fields: [authorAddress], references: [suiAddress])
  comments      Comment[]
}

model Comment {
  id            Int       @id @default(autoincrement())
  postId        String
  authorAddress String
  textContent   String
  createdAt     DateTime  @default(now())

  post          Post      @relation(fields: [postId], references: [objectId], onDelete: Cascade)
  author        User      @relation(fields: [authorAddress], references: [suiAddress], onDelete: Cascade)
}

model Event {
  objectId    String    @id
  title       String
  description String
  eventDate   DateTime
  createdAt   DateTime  @default(now())

  rsvps       Rsvp[]
}

model Rsvp {
  id         Int      @id @default(autoincrement())
  eventId    String
  suiAddress String
  ticketId   String
  createdAt  DateTime @default(now())

  event      Event    @relation(fields: [eventId], references: [objectId], onDelete: Cascade)
  user       User     @relation(fields: [suiAddress], references: [suiAddress], onDelete: Cascade)
}

model Quest {
  objectId    String    @id
  title       String
  description String
  reward      Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  completions QuestCompletion[]
}

model QuestCompletion {
  id         Int      @id @default(autoincrement())
  questId    String
  suiAddress String
  createdAt  DateTime @default(now())

  quest      Quest    @relation(fields: [questId], references: [objectId], onDelete: Cascade)
  user       User     @relation(fields: [suiAddress], references: [suiAddress], onDelete: Cascade)
}
